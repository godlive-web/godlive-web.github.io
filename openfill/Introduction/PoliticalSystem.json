      "data": {
        "机构名称": "议会内阁/神界内阁",
        "介绍": "议会内阁，别称“神界内阁”。内阁选举出现总大臣与系主，总大臣对议会负责，系主则负责组建与维持内阁完整。现有体系中，内阁仅负责管理周边地区，而其他国家地区的事务通常由本地官政宫内的内阁负责。其他国家也会定期派出各城级议会大臣前往盛元城参加议会。",
        "管辖区域": "神界",
        "设立地点": "盛元城－官政宫－议会厅",
        "管理层": "总大臣、系主",
        "上级机构": [],
        "下辖机构": []
